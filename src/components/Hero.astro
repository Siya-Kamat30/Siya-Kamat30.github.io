---
import heroImage from '@assets/images/hero.png';
import Button from '@components/ui/Button.astro';
import { Image } from 'astro:assets';
---

<section
	data-testid="hero"
	class="flex h-screen flex-col-reverse items-center justify-center text-center lg:flex-row"
>
	<div class="mb-10 flex flex-col items-center lg:mb-0 lg:w-1/2">
		<div>
			<h1 class="mb-10 font-monospace text-3xl text-black dark:text-white lg:text-5xl">
				Hi! My name is <span class="text-orange">Jane Doe</span> and I am a web developer based in New
				York.
			</h1>
		</div>
		<div class="mb-10">
			<Button style={'primary'} size={'lg'} class={'flex'} name="learn more">Learn more</Button>
		</div>
	</div>
	<div data-testid="hero-img" class="mb-10 flex w-full items-center justify-center lg:w-1/2">
    <Image
        src={heroImage}
        alt="Siya Kamat"
        format="png"
        width={320}
        height={320}
        loading="eager"
        class="h-64 w-64 rounded-full object-cover object-top shadow-xl ring-4 ring-orange lg:h-80 lg:w-80"
    />
	</div>
</section>
